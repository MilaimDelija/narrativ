# NARRATIV API — Environment Variables
# Copy to .env and fill in values

# Required
DATABASE_URL=postgresql://...          # Neon PostgreSQL connection string
UPSTASH_REDIS_REST_URL=https://...     # Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=...           # Upstash Redis token

# Blockchain anchoring (Polygon Amoy)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
WALLET_PRIVATE_KEY=...                 # For blockchain anchoring

# Optional — semantic content layer
GROQ_API_KEY=...                       # Groq API for LLM embedding endpoint

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://narrativ.neuronium.engineer
